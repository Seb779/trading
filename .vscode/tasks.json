{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Push GitHub",
      "type": "shell",
      "command": "cd ~/Dev/Trading && git add . && git commit -m '${input:commitMessage}' && git push origin main",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Message du commit",
      "default": "update: modifications dashboard"
    }
  ]
}